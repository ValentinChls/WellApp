# =============================================================================
# App d'administration Wellpharma (Next.js) — variables d'environnement
# Copier ce fichier en `.env.local` et renseigner les valeurs.
# =============================================================================

# URL du projet Supabase (publique — exposée au navigateur).
NEXT_PUBLIC_SUPABASE_URL=

# Clé anonyme (publique) Supabase — exposée au navigateur.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service role Supabase — SECRÈTE, ne jamais exposer côté client.
# Utilisée uniquement côté serveur (opérations privilégiées).
SUPABASE_SERVICE_ROLE_KEY=

# URL publique de l'app admin (sert aussi l'endpoint tRPC à /api/trpc).
NEXT_PUBLIC_APP_URL=http://localhost:3000
