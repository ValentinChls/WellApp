# App patient « WPA » (PWA Vite) — variables exposées au client (préfixe VITE_).
# Copier en `.env`. Ne JAMAIS y mettre de secret serveur.

VITE_SUPABASE_URL="https://xxxxxxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# Endpoint tRPC (servi par l'app admin Next.js).
VITE_API_URL="http://localhost:3000/api/trpc"

# Web Push — clé PUBLIQUE VAPID (la privée reste côté serveur).
# Générer (phase notifications) : npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=""
