{
  "name": "@wellpharma/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./engagement": "./src/engagement.ts",
    "./health": "./src/health.ts",
    "./crypto": "./src/crypto.ts"
  },
  "scripts": {
    "db:generate": "prisma generate --schema=prisma/engagement/schema.prisma && prisma generate --schema=prisma/health/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/engagement/schema.prisma && prisma migrate dev --schema=prisma/health/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=prisma/engagement/schema.prisma && prisma migrate deploy --schema=prisma/health/schema.prisma",
    "db:push": "prisma db push --schema=prisma/engagement/schema.prisma && prisma db push --schema=prisma/health/schema.prisma",
    "db:seed": "tsx --env-file=../../.env seed/index.ts",
    "db:studio": "prisma studio --schema=prisma/engagement/schema.prisma",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@wellpharma/shared": "workspace:*"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "@types/node": "^22.10.2",
    "@wellpharma/config": "workspace:*",
    "eslint": "^9.17.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
