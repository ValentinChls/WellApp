# =====================================================================
# Wellpharma — variables d'environnement (exemple)
# Copier en `.env` à la racine. NE JAMAIS committer de vraies valeurs.
# =====================================================================

# ---------------------------------------------------------------------
# DOMAINE ENGAGEMENT (infra standard, UE)
# ---------------------------------------------------------------------
ENGAGEMENT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wellpharma?schema=engagement"

# ---------------------------------------------------------------------
# DOMAINE SANTÉ (HDS-ready)
# Au départ : même instance Supabase, schéma `health`.
# AVANT PROD : pointer vers un Postgres hébergé HDS (cf. README §HDS).
# ---------------------------------------------------------------------
HEALTH_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wellpharma?schema=health"

# ---------------------------------------------------------------------
# CHIFFREMENT at-rest des champs santé (envelope encryption)
# Clé KEK base64 de 32 octets. Générer :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# TODO HDS : déplacer la KEK dans un KMS (jamais en clair en prod).
# ---------------------------------------------------------------------
ENCRYPTION_KEK="REMPLACER_PAR_UNE_CLE_BASE64_32_OCTETS"

# ---------------------------------------------------------------------
# SUPABASE (Auth + Storage)
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # serveur uniquement — JAMAIS exposé au client

# ---------------------------------------------------------------------
# APP ADMIN (Next.js)
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------
# APP PATIENT « WPA » (PWA Vite) — préfixe VITE_ obligatoire pour l'exposition client
# ---------------------------------------------------------------------
VITE_SUPABASE_URL="https://xxxxxxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."
VITE_API_URL="http://localhost:3000/api/trpc"

# PWA — Web Push (clé publique VAPID). Générer la paire (phase notifications) :
#   npx web-push generate-vapid-keys
# La clé PRIVÉE reste côté serveur (jamais VITE_).
VITE_VAPID_PUBLIC_KEY=""

# ---------------------------------------------------------------------
# NOTIFICATIONS (serveur) — Web Push (VAPID) + liens sécurisés
# Générer la paire VAPID : npx web-push generate-vapid-keys
#   → recopier la clé publique aussi dans VITE_VAPID_PUBLIC_KEY ci-dessus.
# ---------------------------------------------------------------------
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@wellpharma.fr"

# Secret de signature des liens sécurisés (HMAC). Générer :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECURE_LINK_SECRET=""

# ---------------------------------------------------------------------
# CHATBOT non-santé (serveur) — LLM via API Claude (Anthropic).
# Sans clé : le chatbot retombe sur sa réponse déterministe locale.
# Les garde-fous (pré-filtre santé, redirection, disclaimer) sont EN DUR,
# indépendants du LLM. Le prompt système est verrouillé côté serveur.
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY=""
CHATBOT_MODEL="claude-opus-4-8"   # optionnel — modèle par défaut
